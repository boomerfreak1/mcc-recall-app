# GitHub Integration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=owner/repo
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Ollama (embeddings + chat)
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:1b

# Mistral API (extraction + classification + chat) — set key for cloud AI, omit for local Ollama
# When configured, Mistral is used for entity extraction, query classification, and chat answers.
# Ollama is kept as fallback and still used for embeddings (nomic-embed-text).
# MISTRAL_API_KEY=your_mistral_api_key
# MISTRAL_CHAT_MODEL=mistral-small-latest

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Data Storage (Railway: /data with persistent volume)
DATA_DIR=/data

# Server
PORT=3000
