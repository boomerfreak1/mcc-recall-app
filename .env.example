# =============================================================================
# Recall — Environment Variables
# =============================================================================
# Copy to .env and fill in your values. For Railway, set these in Settings > Variables.

# --- REQUIRED ---

# GitHub personal access token with repo scope (for fetching documents)
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# GitHub repository to index (owner/repo format)
GITHUB_REPO=owner/repo

# Admin password for triggering indexing from the dashboard
# Generate a strong random value. Used to protect the index endpoint.
ADMIN_PASSWORD=

# --- SECURITY ---

# Secret for verifying GitHub webhook signatures
# Must match the secret configured in your GitHub webhook settings.
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# --- AI / LLM (Optional) ---

# Mistral API key for cloud-based entity extraction, classification, and chat
# When set, Mistral handles extraction and classification; Ollama remains for embeddings.
# Get a key at: https://console.mistral.ai/
# MISTRAL_API_KEY=
# MISTRAL_CHAT_MODEL=mistral-small-latest

# --- INFRASTRUCTURE (defaults work for Docker/Railway) ---

# Embedding provider (default: ollama)
EMBEDDING_PROVIDER=ollama

# Ollama configuration (runs inside the Docker container)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:1b

# ChromaDB configuration (runs inside the Docker container)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Persistent data directory (Railway: /data with mounted volume; local dev: ./data)
DATA_DIR=/data

# Server port
PORT=3000
